{
  "name": "pw-eslint",
  "version": "0.2.2",
  "description": "AST-based static analysis CLI for Playwright test files",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "pw-eslint": "dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "socket.yml"
  ],
  "scripts": {
    "prepare": "husky",
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run build && npm run typecheck",
    "bench": "node bench/run.mjs"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lautaroleonhardt/pw-eslint.git"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "picomatch": "^4.0.0",
    "tinyglobby": "^0.2.0",
    "ts-morph": "^28.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "@types/picomatch": "^3.0.0",
    "eslint": "^10.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "picomatch": "^4.0.0",
    "glob-parent": "^6.0.2",
    "is-glob": "^4.0.3",
    "is-extglob": "^2.1.1",
    "ts-interface-checker": "^1.0.2"
  }
}
